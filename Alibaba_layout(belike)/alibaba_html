<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TradeHub Marketplace</title>

<link rel="stylesheet" href="style.css">
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>

<body>

<!-- TOP NAVBAR -->
<header class="navbar">

    <div class="logo">
        Trade<span>Hub</span>
    </div>

    <div class="search">
        <input type="text" placeholder="Search products, suppliers, factories...">
        <button><i class="fas fa-search"></i></button>
    </div>

    <div class="nav-actions">
        <i class="fas fa-user"></i>
        <i class="fas fa-heart"></i>
        <i class="fas fa-cart-shopping"></i>
    </div>

</header>

<!-- CATEGORY BAR -->
<div class="category-bar">
    <span>🔥 Hot Deals</span>
    <span>Electronics</span>
    <span>Fashion</span>
    <span>Home</span>
    <span>Beauty</span>
    <span>Sports</span>
    <span>Automotive</span>
    <span>Suppliers</span>
</div>

<!-- HERO -->
<section class="hero">

    <div class="hero-text">
        <h1>Global B2B Marketplace</h1>
        <p>Connect with verified suppliers & wholesale manufacturers worldwide</p>
        <button>Start Sourcing</button>
    </div>

</section>

<!-- MAIN LAYOUT -->
<div class="container">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <h3>Categories</h3>

        <ul>
            <li><i class="fas fa-tv"></i> Electronics</li>
            <li><i class="fas fa-shirt"></i> Fashion</li>
            <li><i class="fas fa-couch"></i> Home & Living</li>
            <li><i class="fas fa-person-running"></i> Sports</li>
            <li><i class="fas fa-car"></i> Automotive</li>
            <li><i class="fas fa-gem"></i> Jewelry</li>
        </ul>

        <div class="supplier-box">
            <h4>Become a Supplier</h4>
            <p>Reach millions of buyers globally</p>
            <button>Join Now</button>
        </div>

    </aside>

    <!-- CONTENT -->
    <main>

        <!-- FEATURED -->
        <section class="section">
            <h2>🔥 Trending Deals</h2>

            <div class="grid">

                <div class="card">
                    <span class="badge sale">-30%</span>
                    <img src="https://picsum.photos/seed/p1/400/300">
                    <h4>Wireless Earbuds</h4>
                    <p class="price">$29.99 <del>$49.99</del></p>
                    <button>Buy Now</button>
                </div>

                <div class="card">
                    <span class="badge new">NEW</span>
                    <img src="https://picsum.photos/seed/p2/400/300">
                    <h4>Smart Watch Pro</h4>
                    <p class="price">$89.99</p>
                    <button>Buy Now</button>
                </div>

                <div class="card">
                    <img src="https://picsum.photos/seed/p3/400/300">
                    <h4>Gaming Keyboard</h4>
                    <p class="price">$59.99</p>
                    <button>Buy Now</button>
                </div>

                <div class="card">
                    <img src="https://picsum.photos/seed/p4/400/300">
                    <h4>Bluetooth Speaker</h4>
                    <p class="price">$39.99</p>
                    <button>Buy Now</button>
                </div>

            </div>
        </section>

        <!-- PRODUCTS -->
        <section class="section">
            <h2>📦 All Products</h2>

            <div class="grid">

                <div class="card">
                    <img src="https://picsum.photos/seed/p5/400/300">
                    <h4>Running Shoes</h4>
                    <p class="price">$59.99</p>
                    <button>Buy Now</button>
                </div>

                <div class="card">
                    <img src="https://picsum.photos/seed/p6/400/300">
                    <h4>Backpack Travel</h4>
                    <p class="price">$34.99</p>
                    <button>Buy Now</button>
                </div>

                <div class="card">
                    <img src="https://picsum.photos/seed/p7/400/300">
                    <h4>VR Headset</h4>
                    <p class="price">$129.99</p>
                    <button>Buy Now</button>
                </div>

                <div class="card">
                    <img src="https://picsum.photos/seed/p8/400/300">
                    <h4>Office Chair</h4>
                    <p class="price">$149.99</p>
                    <button>Buy Now</button>
                </div>

            </div>
        </section>

        <!-- SUPPLIERS -->
        <section class="section">
            <h2>🏭 Top Suppliers</h2>

            <div class="supplier-grid">

                <div class="supplier">
                    <img src="https://picsum.photos/seed/s1/100/100">
                    <h4>Shenzhen Tech Co.</h4>
                    <p>Electronics Manufacturer</p>
                </div>

                <div class="supplier">
                    <img src="https://picsum.photos/seed/s2/100/100">
                    <h4>Global Fashion Ltd</h4>
                    <p>Clothing Supplier</p>
                </div>

                <div class="supplier">
                    <img src="https://picsum.photos/seed/s3/100/100">
                    <h4>HomeCraft Industries</h4>
                    <p>Furniture Factory</p>
                </div>

            </div>
        </section>

    </main>

</div>

<!-- FOOTER -->
<footer>

    <div class="footer-grid">

        <div>
            <h3>TradeHub</h3>
            <p>Global B2B marketplace connecting buyers and suppliers worldwide.</p>
        </div>

        <div>
            <h4>Company</h4>
            <p>About</p>
            <p>Careers</p>
            <p>Contact</p>
        </div>

        <div>
            <h4>Help</h4>
            <p>Support</p>
            <p>Shipping</p>
            <p>Returns</p>
        </div>

        <div>
            <h4>Legal</h4>
            <p>Privacy</p>
            <p>Terms</p>
        </div>

    </div>

    <p class="copy">© 2026 TradeHub Marketplace</p>

</footer>

</body>
</html>
